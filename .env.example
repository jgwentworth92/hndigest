# LLM Provider Configuration
# Set the active provider: gemini, claude, openai, local
LLM_PROVIDER=gemini

# Google Gemini
GEMINI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Local OpenAI-compatible endpoint (ollama, vllm, etc.)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=
